{
  "name": "@syyclops/viewer",
  "private": true,
  "scripts": {
    "dev": "bun --filter=@syyclops/web run dev",
    "build": "bun --filter=@syyclops/web run build",
    "typecheck": "bun --filter=* run typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "^1.3.5",
    "@types/stats.js": "^0.17.4"
  }
}
